# ---------- DISK AUTO DETECT ----------
%pre

DIR="/sys/block"
MINSIZE=50
ROOTDRIVE=""

for d in $DIR/nvme* $DIR/sd*; do
    DEV=$(basename "$d")

    if [ -d "$DIR/$DEV" ]; then
        GB=$(( $(cat $DIR/$DEV/size) / 2**21 ))

        if [ $GB -gt $MINSIZE ] && [ -z "$ROOTDRIVE" ]; then
            ROOTDRIVE=$DEV
        fi
    fi
done


cat <<EOF > /tmp/part-include

zerombr
clearpart --drives=$ROOTDRIVE --all --initlabel
ignoredisk --only-use=$ROOTDRIVE
reqpart --add-boot

part /boot/efi --fstype=efi --size=600 --ondisk=$ROOTDRIVE
part /boot --fstype=xfs --size=1024 --ondisk=$ROOTDRIVE
part / --fstype=xfs --size=10240 --grow --ondisk=$ROOTDRIVE

EOF

%end


%include /tmp/part-include


# ---------- EXTRACT SQUASHFS ----------
%post --nochroot

mkdir /mnt/golden
mount -o loop /run/install/repo/golden_root.sqfs /mnt/golden

echo "Extracting golden image..."

rsync -aHAX /mnt/golden/ /mnt/sysimage/

umount /mnt/golden

%end


